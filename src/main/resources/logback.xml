<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console appender (Docker-friendly, no colors) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Application logger -->
    <logger name="org.skopeo" level="INFO" />

    <!-- Ktor loggers -->
    <logger name="io.ktor" level="INFO" />
    <logger name="io.ktor.server.plugins.calllogging" level="INFO" />

    <!-- Netty logger (reduce noise) -->
    <logger name="io.netty" level="WARN" />

    <!-- Console only: containers and cloud platforms collect stdout -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
