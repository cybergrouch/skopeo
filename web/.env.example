# Copy to .env.local and fill in your Firebase project's web app config.
# These are public client values (safe in the browser); the Firebase secret
# stays server-side in Firebase. Find them in: Firebase console → Project
# settings → General → Your apps → SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Backend base URL. Leave empty to use the Vite dev proxy (/api -> :8080).
# In production set this to the deployed API origin, e.g. https://api.skopeo.app
VITE_API_BASE_URL=
