{
  "hosting": {
    "public": "web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/matches/*",
        "run": { "serviceId": "skopeo", "region": "asia-southeast1" }
      },
      {
        "source": "/players/*",
        "run": { "serviceId": "skopeo", "region": "asia-southeast1" }
      },
      {
        "source": "/events/*",
        "run": { "serviceId": "skopeo", "region": "asia-southeast1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
